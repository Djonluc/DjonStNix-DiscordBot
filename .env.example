# BOT CORE
DISCORD_TOKEN=YOUR_BOT_TOKEN
CLIENT_ID=YOUR_BOT_APPLICATION_ID
GUILD_ID=YOUR_SERVER_ID

# CHANNELS
LOG_CHANNEL_ID=YOUR_CHANNEL_ID_FOR_LOGS
WELCOME_CHANNEL_ID=YOUR_CHANNEL_ID_FOR_WELCOME

# ROLES
ADMIN_ROLES=ID1,ID2
WHITELIST_ROLE_NAME=Whitelisted
VERIFIED_ROLE_NAME=Verified

# FIVE-M SERVER
SERVER_NAME=DjonStNix Elite
FIVEM_SERVER_IP=127.0.0.1:30120

# DATABASE (FiveM Database)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=fivem

# RCON (For advanced server moderation)
RCON_HOST=127.0.0.1
RCON_PORT=30120
RCON_PASSWORD=your_rcon_password

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# FIVEM SERVER.CFG CONVARS (add these THERE, not here!)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# These must be added to your server.cfg file so the
# FiveM-side Lua scripts can check Discord roles on connect:
#
#   set discord_bot_token "YOUR_BOT_TOKEN"
#   set discord_guild_id "YOUR_GUILD_ID"
#   set discord_whitelist_role_id "YOUR_WHITELISTED_ROLE_ID"
#   set discord_gate_enabled "true"
#
# To find the Whitelist Role ID:
#   1. Enable Developer Mode in Discord (Settings > Advanced)
#   2. Right-click the "Whitelisted" role > Copy Role ID

# 🚦 PRIORITY QUEUE (Internal API)
QUEUE_PORT=3012
QUEUE_ENABLED=true
QUEUE_VERIFIED_ROLE_NAME=Verified

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 💡 EXPLANATION:
# You do NOT need to use Role IDs (e.g. 1451441172462571654) here.
# The Bot reads the literal NAME of the role from Discord!
# If your Discord role is named "Owner", just list Owner:Priority inside QUEUE_ROLE_PRIORITIES.
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 👑 STAFF TIERS
# Owner:1000
# Developer:950
# Staff:900
#
# 💰 PAID TIERS
# Elite_Plus:850
# Elite:800
# Premium_Plus:750
# Premium:700
# Supporter_Plus:650
# Supporter:600
# Basic_Support:550
#
# ⚪ FREE TIERS
# Verified:0
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
QUEUE_ROLE_PRIORITIES=Owner:1000,Developer:950,Staff:900,Elite_Plus:850,Elite:800,Premium_Plus:750,Premium:700,Supporter_Plus:650,Supporter:600,Basic_Support:550,Verified:0


